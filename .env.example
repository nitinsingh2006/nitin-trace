# N-Trace Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# PRIMARY AI PROVIDER (REQUIRED)
# ============================================
# Claude/Anthropic API Key
# Get your key at: https://console.anthropic.com/
# Format: sk-ant-api03-...
VITE_ANTHROPIC_API_KEY=

# ============================================
# GITHUB INTEGRATION (OPTIONAL)
# ============================================
# GitHub Personal Access Token
# Scope: public_repo only
# Get your token at: https://github.com/settings/tokens
# Format: ghp_...
VITE_GITHUB_PAT=

# ============================================
# ANALYTICS (OPTIONAL)
# ============================================
# Privacy-respecting analytics
# Plausible or Umami domain
VITE_PLAUSIBLE_DOMAIN=n-trace.app

# Error monitoring
# Sentry DSN
VITE_SENTRY_DSN=

# ============================================
# FEATURE FLAGS (OPTIONAL)
# ============================================
# Enable/disable features during development
VITE_ENABLE_EXPORT=true
VITE_ENABLE_SHARE=true
VITE_ENABLE_COLLABORATION=false
VITE_ENABLE_PWA=true

# ============================================
# DEVELOPMENT (OPTIONAL)
# ============================================
# Debug mode - shows additional logging
VITE_DEBUG_MODE=false

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Maximum trace history items
VITE_MAX_HISTORY_ITEMS=100