{
  "name": "n-trace",
  "version": "1.0.0",
  "description": "AI-powered code execution visualizer — Understand your code step-by-step with Claude AI",
  "author": "Nitin Singh",
  "license": "MIT",
  "homepage": "https://n-trace.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/nitinsingh2006/n-trace"
  },
  "keywords": [
    "code-visualizer",
    "execution-trace",
    "ai-debugger",
    "learning-tool",
    "code-animation",
    "claude-ai",
    "programming-education"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js --report-unused-disable-directives --max-warnings 20",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.45.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.0.0",
    "prettier": "^3.3.0",
    "vite": "^8.1.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
