<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1200" y2="630">
      <stop offset="0%" stop-color="#0a0a1a"/>
      <stop offset="100%" stop-color="#14142a"/>
    </linearGradient>
    <linearGradient id="accent" x1="0" y1="0" x2="1200" y2="630">
      <stop offset="0%" stop-color="#00f0ff"/>
      <stop offset="100%" stop-color="#7c3aed"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect x="0" y="0" width="1200" height="4" fill="url(#accent)"/>
  <!-- Logo -->
  <text x="60" y="80" font-family="monospace" font-size="28" fill="#00f0ff" font-weight="bold">⟐ NitinTrace</text>
  <!-- Headline -->
  <text x="60" y="220" font-family="sans-serif" font-size="64" fill="#fff" font-weight="800">See your code</text>
  <text x="60" y="300" font-family="sans-serif" font-size="64" fill="#00f0ff" font-weight="800">come alive</text>
  <!-- Subtitle -->
  <text x="60" y="370" font-family="sans-serif" font-size="22" fill="#999">AI-powered code execution visualizer</text>
  <text x="60" y="404" font-family="sans-serif" font-size="18" fill="#666">Gemini · Groq · 17 Languages · Step-by-Step</text>
  <!-- Code snippet -->
  <rect x="620" y="120" width="520" height="380" rx="16" fill="#14142a" stroke="#2a2a4a" stroke-width="1"/>
  <rect x="620" y="120" width="520" height="40" rx="16" fill="#1a1a34"/>
  <circle cx="642" cy="140" r="6" fill="#ff5f56"/>
  <circle cx="662" cy="140" r="6" fill="#ffbd2e"/>
  <circle cx="682" cy="140" r="6" fill="#27c93f"/>
  <text x="644" y="195" font-family="monospace" font-size="16" fill="#636">1</text>
  <text x="664" y="195" font-family="monospace" font-size="16" fill="#8cf">function</text>
  <text x="720" y="195" font-family="monospace" font-size="16" fill="#e8e">fibonacci(n) {</text>
  <text x="644" y="228" font-family="monospace" font-size="16" fill="#636">2</text>
  <text x="680" y="228" font-family="monospace" font-size="16" fill="#e8e">if</text>
  <text x="704" y="228" font-family="monospace" font-size="16" fill="#e8e">(n &lt;= 1) return n;</text>
  <text x="644" y="261" font-family="monospace" font-size="16" fill="#636">3</text>
  <rect x="640" y="276" width="480" height="28" rx="4" fill="rgba(0,240,255,0.1)"/>
  <text x="656" y="295" font-family="monospace" font-size="16" fill="#f80">4</text>
  <text x="680" y="295" font-family="monospace" font-size="16" fill="#e8e">let a = 0, b = 1;</text>
  <text x="644" y="328" font-family="monospace" font-size="16" fill="#636">5</text>
  <text x="680" y="328" font-family="monospace" font-size="16" fill="#e8e">for</text>
  <text x="712" y="328" font-family="monospace" font-size="16" fill="#e8e">(let i = 2; i &lt;= n; i++) {</text>
  <text x="644" y="361" font-family="monospace" font-size="16" fill="#636">6</text>
  <text x="696" y="361" font-family="monospace" font-size="16" fill="#e8e">let temp = b;</text>
  <text x="644" y="394" font-family="monospace" font-size="16" fill="#636">7</text>
  <text x="696" y="394" font-family="monospace" font-size="16" fill="#e8e">b = a + b;</text>
  <text x="644" y="427" font-family="monospace" font-size="16" fill="#636">8</text>
  <text x="696" y="427" font-family="monospace" font-size="16" fill="#e8e">a = temp;</text>
  <text x="644" y="460" font-family="monospace" font-size="16" fill="#636">9</text>
  <text x="680" y="460" font-family="monospace" font-size="16" fill="#e8e">}</text>
  <!-- Bottom bar -->
  <rect x="0" y="626" width="1200" height="4" fill="url(#accent)"/>
  <text x="60" y="600" font-family="sans-serif" font-size="14" fill="#444">n-trace.vercel.app</text>
</svg>
